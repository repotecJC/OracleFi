"use client";

import { useState, useEffect } from 'react';
import { useCurrentAccount, useSignAndExecuteTransaction } from '@mysten/dapp-kit';
import { toast } from 'sonner';
import { useQueryClient } from '@tanstack/react-query';
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/ui/card';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { buildMintOC } from '@/lib/transactions';
import { SCALING_FACTOR, TREASURY_CAP_ID } from '@/lib/constants';

export function MintOCForm() {
  const currentAccount = useCurrentAccount();
  const queryClient = useQueryClient();
  const { mutate: signAndExecute } = useSignAndExecuteTransaction();
  
  const [recipient, setRecipient] = useState('');
  const [amount, setAmount] = useState('');
  const [isLoading, setIsLoading] = useState(false);

  useEffect(() => {
    if (currentAccount?.address && !recipient) {
      setRecipient(currentAccount.address);
    }
  }, [currentAccount, recipient]);

  const handleMint = () => {
    if (!currentAccount) {
      toast.error('請先連接錢包');
      return;
    }

    if (!recipient) {
      toast.error('請輸入接收地址');
      return;
    }

    const numAmount = parseFloat(amount);
    if (isNaN(numAmount) || numAmount <= 0) {
      toast.error('請輸入有效的數量');
      return;
    }

    if (numAmount > 1000000000) {
      toast.error('超過鑄造上限 (1,000,000,000 OC)');
      return;
    }

    setIsLoading(true);
    try {
      const amountScaled = (numAmount * Number(SCALING_FACTOR)).toString();
      const tx = buildMintOC(TREASURY_CAP_ID, amountScaled, recipient);
      
      signAndExecute({ transaction: tx }, {
        onSuccess: () => {
          toast.success(`成功鑄造 ${amount} OC 給對應地址！`);
          setAmount('');
          setTimeout(() => queryClient.invalidateQueries({ queryKey: ['userOCCoins'] }), 1500);
        },
        onError: (error) => {
          toast.error(`鑄造失敗: ${error.message}`);
        },
        onSettled: () => {
          setIsLoading(false);
        }
      });
    } catch (e: any) {
      toast.error(`發生錯誤: ${e.message}`);
      setIsLoading(false);
    }
  };

  return (
    <Card>
      <CardHeader>
        <CardTitle className="flex items-center gap-2">🪙 鑄造 OC 代幣</CardTitle>
        <CardDescription>管理員鑄造新的 Oracle Coin</CardDescription>
      </CardHeader>
      <CardContent className="space-y-4">
        <div className="text-sm text-yellow-600 dark:text-yellow-500 mb-2">
          ⚠️ 注意：單次最高上限 1,000,000,000 OC
        </div>
        
        <div className="space-y-3">
          <div className="space-y-1">
            <label className="text-xs font-medium pl-1 text-muted-foreground">接收地址</label>
            <Input
              type="text"
              placeholder="0x..."
              value={recipient}
              onChange={(e) => setRecipient(e.target.value)}
              disabled={isLoading || !currentAccount}
            />
          </div>
          
          <div className="space-y-1">
            <label className="text-xs font-medium pl-1 text-muted-foreground">鑄造數量</label>
            <Input
              type="number"
              placeholder="輸入鑄造數量 (OC)"
              value={amount}
              onChange={(e) => setAmount(e.target.value)}
              disabled={isLoading || !currentAccount}
              min="0"
              max="1000000000"
              step="1"
            />
          </div>
        </div>

        <Button 
          className="w-full mt-2" 
          onClick={handleMint} 
          disabled={isLoading || !currentAccount}
        >
          {isLoading ? '處理中...' : '確認鑄造'}
        </Button>
      </CardContent>
    </Card>
  );
}
